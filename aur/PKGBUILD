# Maintainer: your name <your@email.com>
pkgname=rei-music-bin
pkgver=1.2.0
pkgrel=2
pkgdesc="A clean dark-themed desktop music player"
arch=('x86_64')
url="https://github.com/aguasama39/rei"
license=('MIT')
depends=('fuse2' 'libnotify' 'nss' 'libxss' 'libxtst')
options=('!strip')
source=(
    "Rei-${pkgver}.AppImage::https://github.com/aguasama39/rei/releases/download/v${pkgver}/Rei-${pkgver}.AppImage"
    "rei.desktop"
)
sha256sums=('SKIP' 'SKIP')

prepare() {
    chmod +x "Rei-${pkgver}.AppImage"
    "./Rei-${pkgver}.AppImage" --appimage-extract
}

package() {
    # Install app files
    install -d "${pkgdir}/opt/rei"
    cp -r squashfs-root/* "${pkgdir}/opt/rei/"

    # Wrapper script
    install -d "${pkgdir}/usr/bin"
    cat > "${pkgdir}/usr/bin/rei" <<'EOF'
#!/bin/sh
exec /opt/rei/rei "$@"
EOF
    chmod +x "${pkgdir}/usr/bin/rei"

    # Icon
    install -Dm644 squashfs-root/.DirIcon \
        "${pkgdir}/usr/share/icons/hicolor/512x512/apps/rei.png"

    # Desktop entry
    install -Dm644 "${srcdir}/rei.desktop" \
        "${pkgdir}/usr/share/applications/rei.desktop"
}
